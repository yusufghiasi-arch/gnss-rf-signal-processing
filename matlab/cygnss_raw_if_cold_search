function plot_spectra(ch0, ch1, ch2, fs, nfft, save_figures, show_figures, figures_dir)
%PLOT_SPECTRA Plot spectra for three channels.

    f = linspace(-fs/2, fs/2, nfft);

    plot_single_spectrum(ch0, fs, f, nfft, 'ch0', save_figures, show_figures, figures_dir);
    plot_single_spectrum(ch1, fs, f, nfft, 'ch1', save_figures, show_figures, figures_dir);
    plot_single_spectrum(ch2, fs, f, nfft, 'ch2', save_figures, show_figures, figures_dir);

end


function plot_single_spectrum(x, fs, f, nfft, channel_name, save_figures, show_figures, figures_dir)
%PLOT_SINGLE_SPECTRUM Plot spectrum for one channel.

    if length(x) < nfft
        error('Not enough samples in %s for NFFT=%d.', channel_name, nfft);
    end

    xx = double(x(1:nfft));
    xx = xx - mean(xx);

    spectrum_power = fftshift(abs(fft(xx)).^2);
    spectrum_db = 10 * log10(spectrum_power + 1e-12);

    figure;
    plot(f / 1e6, spectrum_db);
    grid on;
    title(['Spectrum - ', channel_name]);
    xlabel('Frequency (MHz)');
    ylabel('Power (dB)');
    finish_figure(['matlab_05_', channel_name, '_spectrum.png'], ...
        save_figures, show_figures, figures_dir);

end


function ca_code = generate_ca_code(prn)
%GENERATE_CA_CODE Generate GPS L1 C/A code with values -1/+1.

    g2_taps = [
        2  6;
        3  7;
        4  8;
        5  9;
        1  9;
        2 10;
        1  8;
        2  9;
        3 10;
        2  3;
        3  4;
        5  6;
        6  7;
        7  8;
        8  9;
        9 10;
        1  4;
        2  5;
        3  6;
        4  7;
        5  8;
        6  9;
        1  3;
        4  6;
        5  7;
        6  8;
        7  9;
        8 10;
        1  6;
        2  7;
        3  8;
        4  9
    ];

    if prn < 1 || prn > 32
        error('PRN must be between 1 and 32.');
    end

    tap1 = g2_taps(prn, 1);
    tap2 = g2_taps(prn, 2);

    g1 = ones(1, 10);
    g2 = ones(1, 10);

    ca_binary = zeros(1, 1023);

    for i = 1:1023

        g1_output = g1(10);
        g2_output = xor(g2(tap1), g2(tap2));

        ca_binary(i) = xor(g1_output, g2_output);

        g1_feedback = xor(g1(3), g1(10));

        g2_feedback = xor(xor(xor(xor(xor(g2(2), g2(3)), g2(6)), g2(8)), g2(9)), g2(10));

        g1 = [g1_feedback, g1(1:9)];
        g2 = [g2_feedback, g2(1:9)];

    end

    ca_code = 1 - 2 * ca_binary;
    ca_code = ca_code(:);

end


function local_code = sampled_ca_code_for_one_ms(prn, fs, code_rate, samples_per_ms)
%SAMPLED_CA_CODE_FOR_ONE_MS Generate sampled GPS C/A code for one 1-ms block.

    ca = generate_ca_code(prn);

    t = (0:samples_per_ms-1)' / fs;

    chip_index = floor(t * code_rate) + 1;
    chip_index(chip_index > 1023) = 1023;

    local_code = ca(chip_index);
    local_code = local_code(:);

end


function ddm_avg = build_ddm(rx_channel, prn, fs, if_hz, code_rate, doppler_bins, num_ms)
%BUILD_DDM Build noncoherently integrated delay-Doppler map.

    samples_per_ms = round(fs * 0.001);
    needed_samples = num_ms * samples_per_ms;

    if length(rx_channel) < needed_samples
        error('Not enough samples in selected channel.');
    end

    rx = double(rx_channel(1:needed_samples));
    rx = rx - mean(rx);
    rx = rx(:);

    t = (0:samples_per_ms-1)' / fs;

    local_code = sampled_ca_code_for_one_ms(prn, fs, code_rate, samples_per_ms);
    code_fft = fft(local_code);

    ddm_sum = zeros(length(doppler_bins), samples_per_ms);

    for m = 1:num_ms

        start_index = (m-1) * samples_per_ms + 1;
        end_index = m * samples_per_ms;

        signal_block = rx(start_index:end_index);
        signal_block = signal_block(:);

        for d = 1:length(doppler_bins)

            fd = doppler_bins(d);

            carrier = exp(-1j * 2*pi*(if_hz + fd) * t);

            signal_wiped = signal_block .* carrier;

            corr_fft = ifft(fft(signal_wiped) .* conj(code_fft));

            ddm_sum(d, :) = ddm_sum(d, :) + abs(corr_fft(:).').^2;

        end

    end

    ddm_avg = ddm_sum / num_ms;

end


function [results_cold, best_result, best_ddm] = cold_search( ...
    rx_channel, channel_name, prn_list, doppler_bins, num_ms, fs, if_hz, code_rate)
%COLD_SEARCH Search PRNs and Doppler bins for strongest correlation peak.

    results_cold = zeros(length(prn_list), 4);

    best_peak = -Inf;
    best_result = struct();
    best_ddm = [];

    fprintf('\n');
    fprintf('Starting CYGNSS cold search...\n');
    fprintf('Channel = %s\n', channel_name);
    fprintf('num_ms = %d\n', num_ms);

    for p = 1:length(prn_list)

        prn = prn_list(p);

        ddm_avg = build_ddm( ...
            rx_channel, ...
            prn, ...
            fs, ...
            if_hz, ...
            code_rate, ...
            doppler_bins, ...
            num_ms);

        [max_value, max_index] = max(ddm_avg(:));
        [doppler_index, delay_index] = ind2sub(size(ddm_avg), max_index);

        best_doppler = doppler_bins(doppler_index);
        best_delay = delay_index;

        results_cold(p, 1) = prn;
        results_cold(p, 2) = best_doppler;
        results_cold(p, 3) = best_delay;
        results_cold(p, 4) = max_value;

        fprintf('PRN %2d | Peak = %.6e | Doppler = %+8.1f Hz | Delay = %d\n', ...
            prn, max_value, best_doppler, best_delay);

        if max_value > best_peak
            best_peak = max_value;

            best_result.prn = prn;
            best_result.best_doppler = best_doppler;
            best_result.best_delay = best_delay;
            best_result.peak = max_value;

            best_ddm = ddm_avg;
        end

    end

end


function plot_cold_search_results( ...
    results_cold, channel_name, num_ms, save_figures, show_figures, figures_dir)
%PLOT_COLD_SEARCH_RESULTS Plot strongest peak for each PRN.

    figure;
    bar(results_cold(:,1), results_cold(:,4));
    grid on;
    title(['CYGNSS Raw IF cold search - ', channel_name, ' - ', num2str(num_ms), ' ms']);
    xlabel('PRN');
    ylabel('Peak power');
    finish_figure('matlab_05_cold_search_peak_by_prn.png', ...
        save_figures, show_figures, figures_dir);

end


function print_peak_quality(results_cold, best_result)
%PRINT_PEAK_QUALITY Print peak quality metrics.

    peaks = results_cold(:,4);
    sorted_peaks = sort(peaks, 'descend');

    fprintf('\n');
    fprintf('Best cold-search result:\n');
    fprintf('Best PRN = %d\n', best_result.prn);
    fprintf('Best Doppler = %.1f Hz\n', best_result.best_doppler);
    fprintf('Best delay = %d\n', best_result.best_delay);
    fprintf('Best peak = %.6e\n', best_result.peak);

    fprintf('\n');
    fprintf('Cold-search peak quality:\n');
    fprintf('Best / second best = %.6f\n', sorted_peaks(1) / sorted_peaks(2));
    fprintf('Best / median = %.6f\n', sorted_peaks(1) / median(peaks));
    fprintf('Best / mean = %.6f\n', sorted_peaks(1) / mean(peaks));

end


function detailed_ddm_analysis( ...
    rx_channel, ...
    channel_name, ...
    selected_prn, ...
    center_doppler_hz, ...
    num_ms, ...
    fs, ...
    if_hz, ...
    code_rate, ...
    fine_doppler_half_width_hz, ...
    fine_doppler_step_hz, ...
    delay_window_samples, ...
    doppler_window_hz, ...
    save_figures, ...
    show_figures, ...
    figures_dir)
%DETAILED_DDM_ANALYSIS Build and plot detailed DDM for selected PRN.

    doppler_bins_fine = center_doppler_hz - fine_doppler_half_width_hz : ...
        fine_doppler_step_hz : ...
        center_doppler_hz + fine_doppler_half_width_hz;

    ddm_avg = build_ddm( ...
        rx_channel, ...
        selected_prn, ...
        fs, ...
        if_hz, ...
        code_rate, ...
        doppler_bins_fine, ...
        num_ms);

    [max_value, max_index] = max(ddm_avg(:));
    [doppler_index, delay_index] = ind2sub(size(ddm_avg), max_index);

    best_doppler = doppler_bins_fine(doppler_index);
    best_delay = delay_index;

    fprintf('\n');
    fprintf('Detailed DDM result:\n');
    fprintf('Channel = %s\n', channel_name);
    fprintf('PRN = %d\n', selected_prn);
    fprintf('Best Doppler = %.1f Hz\n', best_doppler);
    fprintf('Best delay = %d samples\n', best_delay);
    fprintf('Peak = %.6e\n', max_value);

    samples_per_ms = round(fs * 0.001);
    delay_axis = 1:samples_per_ms;

    %% Full DDM

    figure;
    imagesc(delay_axis, doppler_bins_fine, ddm_avg);
    axis xy;
    colorbar;
    grid on;
    hold on;
    plot(best_delay, best_doppler, 'wo', 'MarkerSize', 10, 'LineWidth', 2);
    title(['Detailed DDM - ', channel_name, ' - PRN ', num2str(selected_prn)]);
    xlabel('Delay sample');
    ylabel('Doppler (Hz)');
    finish_figure('matlab_05_detailed_ddm_full.png', ...
        save_figures, show_figures, figures_dir);

    %% Zoomed DDM

    delay_min = max(1, best_delay - delay_window_samples);
    delay_max = min(samples_per_ms, best_delay + delay_window_samples);

    doppler_min = best_doppler - doppler_window_hz;
    doppler_max = best_doppler + doppler_window_hz;

    doppler_rows = doppler_bins_fine >= doppler_min & doppler_bins_fine <= doppler_max;

    figure;
    imagesc(delay_min:delay_max, ...
        doppler_bins_fine(doppler_rows), ...
        ddm_avg(doppler_rows, delay_min:delay_max));
    axis xy;
    colorbar;
    grid on;
    hold on;
    plot(best_delay, best_doppler, 'wo', 'MarkerSize', 10, 'LineWidth', 2);
    title(['Zoomed DDM - ', channel_name, ' - PRN ', num2str(selected_prn)]);
    xlabel('Delay sample');
    ylabel('Doppler (Hz)');
    finish_figure('matlab_05_detailed_ddm_zoomed.png', ...
        save_figures, show_figures, figures_dir);

    %% Delay waveform

    best_delay_waveform = ddm_avg(doppler_index, :);

    figure;
    plot(delay_axis, best_delay_waveform);
    grid on;
    hold on;
    plot(best_delay, max_value, 'o', 'MarkerSize', 8, 'LineWidth', 2);
    title(['Delay waveform - PRN ', num2str(selected_prn), ...
        ' - Doppler ', num2str(best_doppler), ' Hz']);
    xlabel('Delay sample');
    ylabel('Power');
    finish_figure('matlab_05_delay_waveform.png', ...
        save_figures, show_figures, figures_dir);

    %% Doppler waveform

    best_doppler_waveform = ddm_avg(:, best_delay);

    figure;
    plot(doppler_bins_fine, best_doppler_waveform);
    grid on;
    hold on;
    plot(best_doppler, max_value, 'o', 'MarkerSize', 8, 'LineWidth', 2);
    title(['Doppler waveform - PRN ', num2str(selected_prn), ...
        ' - delay ', num2str(best_delay)]);
    xlabel('Doppler (Hz)');
    ylabel('Power');
    finish_figure('matlab_05_doppler_waveform.png', ...
        save_figures, show_figures, figures_dir);

end
