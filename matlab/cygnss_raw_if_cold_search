% cygnss_raw_if_cold_search.m
%
% CYGNSS raw IF processing demo.
%
% This script is a cleaned GitHub/portfolio version of the CYGNSS raw IF
% workflow developed in MATLAB and then translated to Python.
%
% Workflow:
% 1. Read CYGNSS metadata file
% 2. Read CYGNSS raw data file
% 3. Remove DRT0 header if present
% 4. Unpack CYGNSS 2-bit sign-magnitude samples
% 5. Separate channels:
%    - Channel 0: zenith navigation antenna
%    - Channel 1: nadir science antenna
%    - Channel 2: nadir science antenna
% 6. Plot:
%    - channel waveforms
%    - channel histograms
%    - channel spectra
% 7. Perform cold search over PRNs and Doppler bins
% 8. Plot strongest peak by PRN
% 9. Report best PRN, Doppler, delay, and peak quality
% 10. Build detailed DDM for selected/best PRN
% 11. Plot:
%    - full DDM
%    - zoomed DDM
%    - delay waveform
%    - Doppler waveform
%
% Important:
% Large .bin files should NOT be uploaded to GitHub.
% Place CYGNSS raw .bin files locally in the data/ folder.
%
% Author: Yusof Ghiasi

clear; clc; close all;

%% User settings

META_FILE = 'data/cyg04_raw_if_s20250407_035355_e20250407_035455_meta.bin';
DATA_FILE = 'data/cyg04_raw_if_s20250407_035355_e20250407_035455_data.bin';

% CYGNSS constants used in the processing workflow
FS = 16.0362e6;
IF_HZ = 3.8722e6;
CODE_RATE = 1.023e6;

% Number of raw bytes to read from the data file
NUM_BYTES_TO_READ = 3000000;

% FFT size for spectrum plots
NFFT_SPECTRUM = 262144;

% Cold search settings
COLD_SEARCH_CHANNEL = 'ch1';       % 'ch0', 'ch1', or 'ch2'
COLD_SEARCH_NUM_MS = 20;
PRN_LIST = 1:32;
COLD_DOPPLER_BINS = -10000:500:10000;

% Detailed DDM settings
% If AUTO_DETAILED_FROM_COLD_SEARCH is true, the detailed DDM uses the best
% PRN and Doppler found in the cold search.
AUTO_DETAILED_FROM_COLD_SEARCH = true;

DETAILED_CHANNEL = 'ch2';          % used only if AUTO_DETAILED_FROM_COLD_SEARCH is false
SELECTED_PRN = 10;
CENTER_DOPPLER_HZ = 1500;
DETAILED_NUM_MS = 100;
FINE_DOPPLER_HALF_WIDTH_HZ = 3000;
FINE_DOPPLER_STEP_HZ = 100;

% Zoomed DDM window
DELAY_WINDOW_SAMPLES = 600;
DOPPLER_WINDOW_HZ = 1500;

% Figure options
SAVE_FIGURES = true;
SHOW_FIGURES = true;
FIGURES_DIR = 'figures';

%% Main workflow

fprintf('CYGNSS Raw IF Processing Demo\n');
fprintf('=============================\n');
fprintf('Metadata file: %s\n', META_FILE);
fprintf('Data file: %s\n', DATA_FILE);

%% Read metadata

meta = read_uint8_file(META_FILE, []);

metadata = parse_drt0_metadata(meta);

print_metadata(metadata, length(meta));

samples_per_ms = round(FS * 0.001);

fprintf('\n');
fprintf('Using Fs = %.6f MHz\n', FS / 1e6);
fprintf('Using IF = %.6f MHz\n', IF_HZ / 1e6);
fprintf('Samples per 1 ms = %d\n', samples_per_ms);

%% Read raw data

raw = read_uint8_file(DATA_FILE, NUM_BYTES_TO_READ);

fprintf('\n');
fprintf('Read data bytes = %d\n', length(raw));

fprintf('\n');
fprintf('First 40 data bytes:\n');
disp(raw(1:min(40, length(raw))).');

if length(raw) >= 5
    first4_test = char(raw(2:5).');
    if strcmp(first4_test, 'DRT')
        fprintf('DRT header seems present in data file\n');
    end
end

%% Split and unpack channels

[ch0, ch1, ch2] = split_cygnss_channels(raw);

fprintf('\n');
fprintf('Channel 0 samples = %d\n', length(ch0));
fprintf('Channel 1 samples = %d\n', length(ch1));
fprintf('Channel 2 samples = %d\n', length(ch2));

%% Basic plots

plot_channels(ch0, ch1, ch2, 2000, SAVE_FIGURES, SHOW_FIGURES, FIGURES_DIR);

plot_histograms(ch0, ch1, ch2, SAVE_FIGURES, SHOW_FIGURES, FIGURES_DIR);

plot_spectra(ch0, ch1, ch2, FS, NFFT_SPECTRUM, SAVE_FIGURES, SHOW_FIGURES, FIGURES_DIR);

%% Cold search

rx_channel = select_channel(ch0, ch1, ch2, COLD_SEARCH_CHANNEL);

[results_cold, best_result, best_ddm] = cold_search( ...
    rx_channel, ...
    COLD_SEARCH_CHANNEL, ...
    PRN_LIST, ...
    COLD_DOPPLER_BINS, ...
    COLD_SEARCH_NUM_MS, ...
    FS, ...
    IF_HZ, ...
    CODE_RATE);

plot_cold_search_results( ...
    results_cold, ...
    COLD_SEARCH_CHANNEL, ...
    COLD_SEARCH_NUM_MS, ...
    SAVE_FIGURES, ...
    SHOW_FIGURES, ...
    FIGURES_DIR);

print_peak_quality(results_cold, best_result);

%% Detailed DDM

if AUTO_DETAILED_FROM_COLD_SEARCH
    detailed_channel = COLD_SEARCH_CHANNEL;
    selected_prn = best_result.prn;
    center_doppler = best_result.best_doppler;
else
    detailed_channel = DETAILED_CHANNEL;
    selected_prn = SELECTED_PRN;
    center_doppler = CENTER_DOPPLER_HZ;
end

detailed_rx_channel = select_channel(ch0, ch1, ch2, detailed_channel);

detailed_ddm_analysis( ...
    detailed_rx_channel, ...
    detailed_channel, ...
    selected_prn, ...
    center_doppler, ...
    DETAILED_NUM_MS, ...
    FS, ...
    IF_HZ, ...
    CODE_RATE, ...
    FINE_DOPPLER_HALF_WIDTH_HZ, ...
    FINE_DOPPLER_STEP_HZ, ...
    DELAY_WINDOW_SAMPLES, ...
    DOPPLER_WINDOW_HZ, ...
    SAVE_FIGURES, ...
    SHOW_FIGURES, ...
    FIGURES_DIR);


%% Local functions

function data = read_uint8_file(filename, count)
%READ_UINT8_FILE Read uint8 data from a binary file.

    if ~isfile(filename)
        error(['Could not find file:\n%s\n\n' ...
               'Place the file in the data/ folder or update the filename.'], filename);
    end

    fid = fopen(filename, 'rb');

    if fid < 0
        error('Could not open file: %s', filename);
    end

    cleanupObj = onCleanup(@() fclose(fid));

    if isempty(count)
        data = fread(fid, inf, 'uint8=>uint8');
    else
        data = fread(fid, count, 'uint8=>uint8');
    end

end


function metadata = parse_drt0_metadata(meta)
%PARSE_DRT0_METADATA Parse first DRT0 metadata block.

    if length(meta) < 36
        error('Metadata file is too short to contain DRT0 block.');
    end

    scid = meta(1);
    drt0 = meta(2:36);

    packet_type = char(drt0(1:4).');

    gps_week = double(typecast(uint8(drt0(5:6)), 'uint16'));
    gps_seconds = double(typecast(uint8(drt0(7:10)), 'uint32'));

    data_format = drt0(11);
    sample_rate = double(typecast(uint8(drt0(12:15)), 'uint32'));

    ch0_frontend = drt0(16);
    ch0_lo = double(typecast(uint8(drt0(17:20)), 'uint32'));

    ch1_frontend = drt0(21);
    ch1_lo = double(typecast(uint8(drt0(22:25)), 'uint32'));

    ch2_frontend = drt0(26);
    ch2_lo = double(typecast(uint8(drt0(27:30)), 'uint32'));

    ch3_frontend = drt0(31);
    ch3_lo = double(typecast(uint8(drt0(32:35)), 'uint32'));

    metadata.spacecraft_id = scid;
    metadata.packet_type = packet_type;
    metadata.gps_week = gps_week;
    metadata.gps_seconds = gps_seconds;
    metadata.data_format = data_format;
    metadata.sample_rate = sample_rate;

    metadata.ch0_frontend = ch0_frontend;
    metadata.ch0_lo = ch0_lo;

    metadata.ch1_frontend = ch1_frontend;
    metadata.ch1_lo = ch1_lo;

    metadata.ch2_frontend = ch2_frontend;
    metadata.ch2_lo = ch2_lo;

    metadata.ch3_frontend = ch3_frontend;
    metadata.ch3_lo = ch3_lo;

end


function print_metadata(metadata, meta_length)
%PRINT_METADATA Print DRT0 metadata information.

    fprintf('\n');
    fprintf('Metadata bytes = %d\n', meta_length);

    fprintf('\n');
    fprintf('DRT0 metadata:\n');
    fprintf('Spacecraft ID = %d\n', metadata.spacecraft_id);
    fprintf('Packet type = %s\n', metadata.packet_type);
    fprintf('GPS week = %d\n', metadata.gps_week);
    fprintf('GPS seconds = %d\n', metadata.gps_seconds);
    fprintf('Data format = %d\n', metadata.data_format);
    fprintf('Sample rate = %.6f MHz\n', metadata.sample_rate / 1e6);

    fprintf('Channel 0 frontend = %d | LO = %.6f MHz\n', ...
        metadata.ch0_frontend, metadata.ch0_lo / 1e6);

    fprintf('Channel 1 frontend = %d | LO = %.6f MHz\n', ...
        metadata.ch1_frontend, metadata.ch1_lo / 1e6);

    fprintf('Channel 2 frontend = %d | LO = %.6f MHz\n', ...
        metadata.ch2_frontend, metadata.ch2_lo / 1e6);

    fprintf('Channel 3 frontend = %d | LO = %.6f MHz\n', ...
        metadata.ch3_frontend, metadata.ch3_lo / 1e6);

end


function [ch0, ch1, ch2] = split_cygnss_channels(raw)
%SPLIT_CYGNSS_CHANNELS Split raw CYGNSS bytes into 3 channels and unpack.

    first4_alt = char(raw(1:min(4, length(raw))).');

    if strcmp(first4_alt, 'DRT0')
        fprintf('Data file starts with DRT0 header, removing first 36 bytes\n');
        raw = raw(37:end);
    else
        fprintf('No DRT0 header removed from data file\n');
    end

    num_groups = floor(length(raw) / 3);

    raw = raw(1:num_groups * 3);

    b0 = raw(1:3:end);
    b1 = raw(2:3:end);
    b2 = raw(3:3:end);

    ch0 = unpack_cygnss_2bit(b0);
    ch1 = unpack_cygnss_2bit(b1);
    ch2 = unpack_cygnss_2bit(b2);

end


function x = unpack_cygnss_2bit(bytes)
%UNPACK_CYGNSS_2BIT Unpack CYGNSS 2-bit sign-magnitude samples.
%
% Each byte contains four 2-bit samples:
% sample 0: bit 8 = sign, bit 7 = magnitude
% sample 1: bit 6 = sign, bit 5 = magnitude
% sample 2: bit 4 = sign, bit 3 = magnitude
% sample 3: bit 2 = sign, bit 1 = magnitude

    bytes = uint8(bytes);
    n = length(bytes);

    x = zeros(n * 4, 1);

    for k = 1:n

        b = bytes(k);

        s0 = bitget(b, 8);
        m0 = bitget(b, 7);

        s1 = bitget(b, 6);
        m1 = bitget(b, 5);

        s2 = bitget(b, 4);
        m2 = bitget(b, 3);

        s3 = bitget(b, 2);
        m3 = bitget(b, 1);

        x(4*k - 3) = signmag_to_value(s0, m0);
        x(4*k - 2) = signmag_to_value(s1, m1);
        x(4*k - 1) = signmag_to_value(s2, m2);
        x(4*k)     = signmag_to_value(s3, m3);

    end

end


function v = signmag_to_value(sign_bit, mag_bit)
%SIGNMAG_TO_VALUE Convert CYGNSS 2-bit sign-magnitude sample to value.

    if mag_bit == 0
        amp = 1;
    else
        amp = 3;
    end

    if sign_bit == 0
        v = amp;
    else
        v = -amp;
    end

end


function rx_channel = select_channel(ch0, ch1, ch2, channel_name)
%SELECT_CHANNEL Return selected channel vector.

    switch lower(channel_name)
        case 'ch0'
            rx_channel = ch0;
        case 'ch1'
            rx_channel = ch1;
        case 'ch2'
            rx_channel = ch2;
        otherwise
            error('Unsupported channel name. Use ch0, ch1, or ch2.');
    end

end


function finish_figure(filename, save_figures, show_figures, figures_dir)
%FINISH_FIGURE Save and/or show current figure.

    if save_figures
        if ~exist(figures_dir, 'dir')
            mkdir(figures_dir);
        end

        saveas(gcf, fullfile(figures_dir, filename));
    end

    if show_figures
        drawnow;
    else
        close(gcf);
    end

end


function plot_channels(ch0, ch1, ch2, n, save_figures, show_figures, figures_dir)
%PLOT_CHANNELS Plot first N samples for each channel.

    n0 = min(n, length(ch0));
    n1 = min(n, length(ch1));
    n2 = min(n, length(ch2));

    figure;
    plot(ch0(1:n0));
    grid on;
    title('Channel 0 - zenith navigation antenna');
    xlabel('Sample number');
    ylabel('Amplitude');
    finish_figure('matlab_05_ch0_time_series.png', save_figures, show_figures, figures_dir);

    figure;
    plot(ch1(1:n1));
    grid on;
    title('Channel 1 - nadir science antenna');
    xlabel('Sample number');
    ylabel('Amplitude');
    finish_figure('matlab_05_ch1_time_series.png', save_figures, show_figures, figures_dir);

    figure;
    plot(ch2(1:n2));
    grid on;
    title('Channel 2 - nadir science antenna');
    xlabel('Sample number');
    ylabel('Amplitude');
    finish_figure('matlab_05_ch2_time_series.png', save_figures, show_figures, figures_dir);

end


